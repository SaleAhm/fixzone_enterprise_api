generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  ORG_ADMIN
  DISPATCH_OFFICER
  PROVIDER
  CITIZEN
}

enum ReportStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  COMPLETED_BY_PROVIDER
  CLOSED
}

enum AssignmentOutcome {
  REJECTED
  TIMED_OUT
}

model Organization {
  id                    String   @id @default(cuid())
  name                  String
  isDemo                Boolean  @default(false)
  demoBatchId           String?
  demoScenario          String?
  demoGeneratedAt       DateTime?
  createdBySuperAdminId String?
  createdAt             DateTime @default(now())

  users   User[]
  reports Report[]

  @@index([isDemo])
  @@index([demoBatchId])
  @@index([demoScenario])
}

model User {
  id                    String   @id @default(cuid())
  email                 String?  @unique
  phone                 String?  @unique
  firebaseUid           String?  @unique
  passwordHash          String?
  fullName              String
  role                  UserRole
  organizationId        String?
  isDemo                Boolean  @default(false)
  demoBatchId           String?
  demoScenario          String?
  demoGeneratedAt       DateTime?
  createdBySuperAdminId String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])

  citizenReports  Report[]       @relation("CitizenReports")
  assignedReports Report[]       @relation("AssignedProviderReports")
  notifications   Notification[]

  @@index([organizationId])
  @@index([isDemo])
  @@index([demoBatchId])
  @@index([demoScenario])
}

model Report {
  id                        String             @id @default(cuid())
  title                     String
  description               String
  category                  String
  location                  String
  latitude                  Float?
  longitude                 Float?
  status                    ReportStatus       @default(PENDING)
  organizationId            String
  citizenId                 String
  assignedProviderId        String?
  assignedAt                DateTime?
  assignmentDeadlineAt      DateTime?
  lastAssignmentOutcome     AssignmentOutcome?
  lastAssignmentReason      String?
  lastAssignmentAt          DateTime?
  lastAssignmentProviderId  String?
  completionNote            String?
  completionImageUrl        String?
  completionImagePath       String?
  evidenceImageUrl          String?
  evidenceImagePath         String?
  completedByProviderAt     DateTime?
  citizenRating             Int?
  citizenFeedback           String?
  completionRejectionReason String?
  isDemo                    Boolean            @default(false)
  demoBatchId               String?
  demoScenario              String?
  demoGeneratedAt           DateTime?
  createdBySuperAdminId     String?
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt

  organization     Organization   @relation(fields: [organizationId], references: [id])
  citizen          User           @relation("CitizenReports", fields: [citizenId], references: [id])
  assignedProvider User?          @relation("AssignedProviderReports", fields: [assignedProviderId], references: [id])
  notifications    Notification[]

  @@index([organizationId])
  @@index([citizenId])
  @@index([assignedProviderId])
  @@index([status])
  @@index([isDemo])
  @@index([demoBatchId])
  @@index([demoScenario])
}

model Notification {
  id                    String   @id @default(cuid())
  userId                String
  reportId              String?
  type                  String
  title                 String
  message               String
  read                  Boolean  @default(false)
  isDemo                Boolean  @default(false)
  demoBatchId           String?
  demoScenario          String?
  demoGeneratedAt       DateTime?
  createdBySuperAdminId String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  report Report? @relation(fields: [reportId], references: [id])

  @@index([userId, read])
  @@index([reportId])
  @@index([createdAt])
  @@index([isDemo])
  @@index([demoBatchId])
  @@index([demoScenario])
}

model DemoAuditLog {
  id          String   @id @default(cuid())
  action      String
  actorUserId String
  demoBatchId String?
  scenario    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([action])
  @@index([actorUserId])
  @@index([demoBatchId])
  @@index([createdAt])
}

model PlatformSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model PlatformBackup {
  id            String   @id @default(cuid())
  fileName      String   @unique
  filePath      String
  sizeBytes     Int
  status        String   @default("READY")
  createdById   String
  restoredAt    DateTime?
  restoredById  String?
  createdAt     DateTime @default(now())

  @@index([createdAt])
  @@index([createdById])
  @@index([status])
}
