generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  ORG_ADMIN
  DISPATCH_OFFICER
  PROVIDER
  PENDING_PROVIDER
  CITIZEN
}

enum ReportStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  COMPLETED_BY_PROVIDER
  CLOSED
}

enum AssignmentOutcome {
  REJECTED
  TIMED_OUT
}

enum OrganizationType {
  FEDERAL
  STATE
  LOCAL_GOVERNMENT
  AGENCY
  CORPORATE
  ESTATE
  CAMPUS
  COMMUNITY
  GOVERNMENT
  FEDERAL_AGENCY
  STATE_AGENCY
  UNIVERSITY
  HOSPITAL
  UTILITY_COMPANY
  PRIVATE_FACILITY
  OTHER
}

enum SubscriptionPlan {
  FREE
  DEMO
  STARTER
  PROFESSIONAL
  GOVERNMENT
  ENTERPRISE
}

enum BillingStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
}

enum ProviderEngagementType {
  INTERNAL_STAFF
  EXTERNAL_CONTRACTOR
}

enum AccountStatus {
  PENDING_INVITE
  PENDING_APPROVAL
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum IdentityVerificationStatus {
  UNVERIFIED
  PHONE_VERIFIED
  EMAIL_VERIFIED
  ID_PENDING
  ID_VERIFIED
  FACE_PENDING
  FACE_VERIFIED
  ADDRESS_PENDING
  ADDRESS_VERIFIED
  BUSINESS_VERIFIED
  ENTERPRISE_VERIFIED
}

enum IdentityType {
  INDIVIDUAL
  PROVIDER_INDIVIDUAL
  BUSINESS
  ORGANIZATION_REPRESENTATIVE
  GOVERNMENT_REPRESENTATIVE
}

enum KycSubmissionType {
  GOVERNMENT_ID
  FACE_SELFIE
  ADDRESS_PROOF
  BUSINESS_DOCUMENT
  PROFESSIONAL_LICENSE
}

enum KycSubmissionStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  EXPIRED
}

enum EvidenceRelatedEntityType {
  REPORT
  KYC_SUBMISSION
  PROVIDER
  ORGANIZATION
  SERVICE_REQUEST
  DISPUTE
  USER
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  AWAITING_CLIENT_RESPONSE
  AWAITING_PROVIDER_RESPONSE
  RESOLVED
  REJECTED
  ESCALATED
  CLOSED
}

enum DisputePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum PlatformEntitlementPlan {
  FREE
  VERIFIED
  PERSONAL_PLUS
  PROFESSIONAL
  BUSINESS
  ENTERPRISE
  GOVERNMENT
}

model Organization {
  id                     String             @id @default(cuid())
  name                   String
  type                   OrganizationType   @default(LOCAL_GOVERNMENT)
  status                 OrganizationStatus @default(ACTIVE)
  parentId               String?
  tenantCode             String?
  contactEmail           String?
  contactPhone           String?
  address                String?
  state                  String?
  lga                    String?
  country                String?            @default("Nigeria")
  profileData            Json?
  subscriptionPlan       SubscriptionPlan   @default(FREE)
  billingStatus          BillingStatus      @default(TRIAL)
  subscriptionStartAt    DateTime?
  subscriptionEndAt      DateTime?
  allowedUsers           Int?
  allowedProviders       Int?
  allowedReportsPerMonth Int?
  allowedStorageMb       Int?
  enabledModules         Json?
  isDemo                 Boolean            @default(false)
  demoBatchId            String?
  demoScenario           String?
  demoGeneratedAt        DateTime?
  createdBySuperAdminId  String?
  createdAt              DateTime           @default(now())

  users               User[]
  reports             Report[]
  parent              Organization?          @relation("OrganizationHierarchy", fields: [parentId], references: [id])
  children            Organization[]         @relation("OrganizationHierarchy")
  providerLinks       ProviderOrganization[]
  invitations         Invitation[]
  evidenceRecords     EvidenceRecord[]
  disputeCases        DisputeCase[]
  complianceAuditLogs ComplianceAuditLog[]

  @@index([parentId])
  @@index([type])
  @@index([status])
  @@index([subscriptionPlan])
  @@index([billingStatus])
  @@index([isDemo])
  @@index([demoBatchId])
  @@index([demoScenario])
}

model User {
  id                         String                     @id @default(cuid())
  secureZoneId               String?                    @unique
  email                      String?                    @unique
  phone                      String?                    @unique
  firebaseUid                String?                    @unique
  providerId                 String?                    @unique
  passwordHash               String?
  fullName                   String
  role                       UserRole
  accountStatus              AccountStatus              @default(ACTIVE)
  organizationId             String?
  providerEngagementType     ProviderEngagementType?
  serviceCategories          Json?
  coverageAreas              Json?
  profileData                Json?
  subscriptionPlan           SubscriptionPlan?
  identityVerificationStatus IdentityVerificationStatus @default(UNVERIFIED)
  identityVerificationLevel  Int                        @default(0)
  trustScore                 Int                        @default(0)
  identityType               IdentityType               @default(INDIVIDUAL)
  phoneVerifiedAt            DateTime?
  emailVerifiedAt            DateTime?
  idVerifiedAt               DateTime?
  faceVerifiedAt             DateTime?
  addressVerifiedAt          DateTime?
  businessVerifiedAt         DateTime?
  enterpriseVerifiedAt       DateTime?
  serviceZones               Json?
  isDemo                     Boolean                    @default(false)
  demoBatchId                String?
  demoScenario               String?
  demoGeneratedAt            DateTime?
  createdBySuperAdminId      String?
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])

  citizenReports          Report[]               @relation("CitizenReports")
  assignedReports         Report[]               @relation("AssignedProviderReports")
  notifications           Notification[]
  providerOrganizations   ProviderOrganization[]
  sentInvitations         Invitation[]           @relation("InvitationInviter")
  acceptedInvitations     Invitation[]           @relation("InvitationAcceptedUser")
  kycSubmissions          KycSubmission[]        @relation("KycSubmissionUser")
  reviewedKycSubmissions  KycSubmission[]        @relation("KycSubmissionReviewer")
  loginHistory            LoginHistory[]
  ownedEvidenceRecords    EvidenceRecord[]       @relation("EvidenceOwner")
  uploadedEvidenceRecords EvidenceRecord[]       @relation("EvidenceUploader")
  openedDisputes          DisputeCase[]          @relation("DisputeOpenedBy")
  disputesAgainst         DisputeCase[]          @relation("DisputeAgainstUser")
  reviewedDisputes        DisputeCase[]          @relation("DisputeClosedBy")
  disputeMessages         DisputeMessage[]
  entitlement             UserEntitlement?
  complianceAuditLogs     ComplianceAuditLog[]   @relation("ComplianceAuditActor")

  @@index([organizationId])
  @@index([secureZoneId])
  @@index([identityVerificationStatus])
  @@index([identityType])
  @@index([accountStatus])
  @@index([isDemo])
  @@index([demoBatchId])
  @@index([demoScenario])
}

model KycSubmission {
  id              String              @id @default(cuid())
  userId          String
  submissionType  KycSubmissionType
  status          KycSubmissionStatus @default(SUBMITTED)
  submittedAt     DateTime            @default(now())
  reviewedAt      DateTime?
  reviewedById    String?
  rejectionReason String?
  documentUrl     String?
  evidenceFileRef String?
  metadata        Json?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  user       User  @relation("KycSubmissionUser", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("KycSubmissionReviewer", fields: [reviewedById], references: [id])

  @@index([userId, status])
  @@index([submissionType])
  @@index([status])
  @@index([reviewedById])
  @@index([submittedAt])
}

model LoginHistory {
  id            String   @id @default(cuid())
  userId        String?
  email         String?
  loginAt       DateTime @default(now())
  ipAddress     String?
  userAgent     String?
  success       Boolean
  failureReason String?
  metadata      Json?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, loginAt])
  @@index([email])
  @@index([success])
  @@index([loginAt])
}

model EvidenceRecord {
  id                String                    @id @default(cuid())
  ownerUserId       String?
  organizationId    String?
  relatedEntityType EvidenceRelatedEntityType
  relatedEntityId   String
  fileUrl           String
  fileType          String?
  uploadedById      String
  uploadedAt        DateTime                  @default(now())
  description       String?
  metadata          Json?
  checksum          String?

  ownerUser    User?         @relation("EvidenceOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  uploadedBy   User          @relation("EvidenceUploader", fields: [uploadedById], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([ownerUserId, uploadedAt])
  @@index([organizationId, uploadedAt])
  @@index([relatedEntityType, relatedEntityId])
  @@index([uploadedById])
}

model DisputeCase {
  id                String          @id @default(cuid())
  caseNumber        String          @unique
  openedById        String
  againstUserId     String?
  organizationId    String?
  relatedEntityType String
  relatedEntityId   String
  title             String
  description       String
  status            DisputeStatus   @default(OPEN)
  priority          DisputePriority @default(MEDIUM)
  assignedAdminId   String?
  resolutionSummary String?
  closedById        String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  escalatedAt       DateTime?
  closedAt          DateTime?

  openedBy     User             @relation("DisputeOpenedBy", fields: [openedById], references: [id])
  againstUser  User?            @relation("DisputeAgainstUser", fields: [againstUserId], references: [id])
  organization Organization?    @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  closedBy     User?            @relation("DisputeClosedBy", fields: [closedById], references: [id])
  messages     DisputeMessage[]

  @@index([openedById, createdAt])
  @@index([againstUserId])
  @@index([assignedAdminId])
  @@index([organizationId, createdAt])
  @@index([status])
  @@index([relatedEntityType, relatedEntityId])
}

model DisputeMessage {
  id        String   @id @default(cuid())
  disputeId String
  authorId  String
  message   String
  metadata  Json?
  createdAt DateTime @default(now())

  dispute DisputeCase @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  author  User        @relation(fields: [authorId], references: [id])

  @@index([disputeId, createdAt])
  @@index([authorId])
}

model UserEntitlement {
  id                        String                  @id @default(cuid())
  userId                    String                  @unique
  plan                      PlatformEntitlementPlan @default(FREE)
  canAccessServiceModule    Boolean                 @default(true)
  canUsePremiumProvider     Boolean                 @default(false)
  canOpenDispute            Boolean                 @default(true)
  canUploadEvidence         Boolean                 @default(true)
  canUsePrioritySupport     Boolean                 @default(false)
  requiredVerificationLevel Int                     @default(0)
  metadata                  Json?
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([plan])
}

model ComplianceAuditLog {
  id             String    @id @default(cuid())
  actorId        String?
  actorRole      UserRole?
  organizationId String?
  action         String
  entityType     String?
  entityId       String?
  metadata       Json?
  createdAt      DateTime  @default(now())

  actor        User?         @relation("ComplianceAuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([actorId, createdAt])
  @@index([organizationId, createdAt])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model Invitation {
  id                    String           @id @default(cuid())
  email                 String?
  phone                 String?
  fullName              String
  role                  UserRole
  status                InvitationStatus @default(PENDING)
  temporaryPasswordHash String?
  inviteCode            String           @unique
  organizationId        String?
  invitedById           String
  acceptedUserId        String?
  metadata              Json?
  expiresAt             DateTime?
  acceptedAt            DateTime?
  revokedAt             DateTime?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])
  invitedBy    User          @relation("InvitationInviter", fields: [invitedById], references: [id])
  acceptedUser User?         @relation("InvitationAcceptedUser", fields: [acceptedUserId], references: [id])

  @@index([organizationId])
  @@index([invitedById])
  @@index([status])
  @@index([role])
  @@index([email])
  @@index([phone])
  @@index([createdAt])
}

model ProviderOrganization {
  id             String   @id @default(cuid())
  providerId     String
  organizationId String
  isPrimary      Boolean  @default(false)
  active         Boolean  @default(true)
  serviceZones   Json?
  createdAt      DateTime @default(now())

  provider     User         @relation(fields: [providerId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([providerId, organizationId])
  @@index([organizationId, active])
  @@index([providerId, active])
}

model Report {
  id                        String             @id @default(cuid())
  title                     String
  description               String
  category                  String
  location                  String
  latitude                  Float?
  longitude                 Float?
  status                    ReportStatus       @default(PENDING)
  organizationId            String
  citizenId                 String
  assignedProviderId        String?
  assignedAt                DateTime?
  assignmentDeadlineAt      DateTime?
  lastAssignmentOutcome     AssignmentOutcome?
  lastAssignmentReason      String?
  lastAssignmentAt          DateTime?
  lastAssignmentProviderId  String?
  completionNote            String?
  completionImageUrl        String?
  completionImagePath       String?
  evidenceImageUrl          String?
  evidenceImagePath         String?
  completedByProviderAt     DateTime?
  citizenRating             Int?
  citizenFeedback           String?
  completionRejectionReason String?
  isDemo                    Boolean            @default(false)
  demoBatchId               String?
  demoScenario              String?
  demoGeneratedAt           DateTime?
  createdBySuperAdminId     String?
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt

  organization     Organization     @relation(fields: [organizationId], references: [id])
  citizen          User             @relation("CitizenReports", fields: [citizenId], references: [id])
  assignedProvider User?            @relation("AssignedProviderReports", fields: [assignedProviderId], references: [id])
  notifications    Notification[]
  activities       ReportActivity[]

  @@index([organizationId])
  @@index([citizenId])
  @@index([assignedProviderId])
  @@index([status])
  @@index([isDemo])
  @@index([demoBatchId])
  @@index([demoScenario])
}

model ReportActivity {
  id             String        @id @default(cuid())
  reportId       String
  organizationId String
  actorUserId    String?
  actorRole      UserRole?
  actorName      String?
  action         String
  fromStatus     ReportStatus?
  toStatus       ReportStatus?
  providerId     String?
  reason         String?
  note           String?
  metadata       Json?
  createdAt      DateTime      @default(now())

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId, createdAt])
  @@index([organizationId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([action])
}

model Notification {
  id                    String    @id @default(cuid())
  userId                String
  reportId              String?
  type                  String
  title                 String
  message               String
  read                  Boolean   @default(false)
  isDemo                Boolean   @default(false)
  demoBatchId           String?
  demoScenario          String?
  demoGeneratedAt       DateTime?
  createdBySuperAdminId String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  report Report? @relation(fields: [reportId], references: [id])

  @@index([userId, read])
  @@index([reportId])
  @@index([createdAt])
  @@index([isDemo])
  @@index([demoBatchId])
  @@index([demoScenario])
}

model DemoAuditLog {
  id          String   @id @default(cuid())
  action      String
  actorUserId String
  demoBatchId String?
  scenario    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([action])
  @@index([actorUserId])
  @@index([demoBatchId])
  @@index([createdAt])
}

model PlatformSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model PlatformBackup {
  id           String    @id @default(cuid())
  fileName     String    @unique
  filePath     String
  sizeBytes    Int
  status       String    @default("READY")
  createdById  String
  restoredAt   DateTime?
  restoredById String?
  createdAt    DateTime  @default(now())

  @@index([createdAt])
  @@index([createdById])
  @@index([status])
}
