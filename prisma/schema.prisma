generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  ORG_ADMIN
  DISPATCH_OFFICER
  PROVIDER
  PENDING_PROVIDER
  CITIZEN
}

enum ReportStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  COMPLETED_BY_PROVIDER
  CLOSED
}

enum AssignmentOutcome {
  REJECTED
  TIMED_OUT
}

enum OrganizationType {
  FEDERAL
  STATE
  LOCAL_GOVERNMENT
  AGENCY
  CORPORATE
  ESTATE
  CAMPUS
  COMMUNITY
  GOVERNMENT
  FEDERAL_AGENCY
  STATE_AGENCY
  UNIVERSITY
  HOSPITAL
  UTILITY_COMPANY
  PRIVATE_FACILITY
  OTHER
}

enum SubscriptionPlan {
  FREE
  DEMO
  STARTER
  PROFESSIONAL
  GOVERNMENT
  ENTERPRISE
}

enum BillingStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
}

enum ProviderEngagementType {
  INTERNAL_STAFF
  EXTERNAL_CONTRACTOR
}

enum AccountStatus {
  PENDING_INVITE
  PENDING_APPROVAL
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

model Organization {
  id                     String             @id @default(cuid())
  name                   String
  type                   OrganizationType   @default(LOCAL_GOVERNMENT)
  status                 OrganizationStatus @default(ACTIVE)
  parentId               String?
  tenantCode             String?
  contactEmail           String?
  contactPhone           String?
  address                String?
  state                  String?
  lga                    String?
  country                String?            @default("Nigeria")
  profileData            Json?
  subscriptionPlan       SubscriptionPlan   @default(FREE)
  billingStatus          BillingStatus      @default(TRIAL)
  subscriptionStartAt    DateTime?
  subscriptionEndAt      DateTime?
  allowedUsers           Int?
  allowedProviders       Int?
  allowedReportsPerMonth Int?
  allowedStorageMb       Int?
  enabledModules         Json?
  isDemo                 Boolean            @default(false)
  demoBatchId            String?
  demoScenario           String?
  demoGeneratedAt        DateTime?
  createdBySuperAdminId  String?
  createdAt              DateTime           @default(now())

  users         User[]
  reports       Report[]
  parent        Organization?          @relation("OrganizationHierarchy", fields: [parentId], references: [id])
  children      Organization[]         @relation("OrganizationHierarchy")
  providerLinks ProviderOrganization[]
  invitations   Invitation[]

  @@index([parentId])
  @@index([type])
  @@index([status])
  @@index([subscriptionPlan])
  @@index([billingStatus])
  @@index([isDemo])
  @@index([demoBatchId])
  @@index([demoScenario])
}

model User {
  id                     String                  @id @default(cuid())
  email                  String?                 @unique
  phone                  String?                 @unique
  firebaseUid            String?                 @unique
  providerId             String?                 @unique
  passwordHash           String?
  fullName               String
  role                   UserRole
  accountStatus          AccountStatus           @default(ACTIVE)
  organizationId         String?
  providerEngagementType ProviderEngagementType?
  serviceCategories      Json?
  coverageAreas          Json?
  profileData            Json?
  subscriptionPlan       SubscriptionPlan?
  serviceZones           Json?
  isDemo                 Boolean                 @default(false)
  demoBatchId            String?
  demoScenario           String?
  demoGeneratedAt        DateTime?
  createdBySuperAdminId  String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])

  citizenReports        Report[]               @relation("CitizenReports")
  assignedReports       Report[]               @relation("AssignedProviderReports")
  notifications         Notification[]
  providerOrganizations ProviderOrganization[]
  sentInvitations       Invitation[]           @relation("InvitationInviter")
  acceptedInvitations   Invitation[]           @relation("InvitationAcceptedUser")

  @@index([organizationId])
  @@index([accountStatus])
  @@index([isDemo])
  @@index([demoBatchId])
  @@index([demoScenario])
}

model Invitation {
  id                    String           @id @default(cuid())
  email                 String?
  phone                 String?
  fullName              String
  role                  UserRole
  status                InvitationStatus @default(PENDING)
  temporaryPasswordHash String?
  inviteCode            String           @unique
  organizationId        String?
  invitedById           String
  acceptedUserId        String?
  metadata              Json?
  expiresAt             DateTime?
  acceptedAt            DateTime?
  revokedAt             DateTime?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])
  invitedBy    User          @relation("InvitationInviter", fields: [invitedById], references: [id])
  acceptedUser User?         @relation("InvitationAcceptedUser", fields: [acceptedUserId], references: [id])

  @@index([organizationId])
  @@index([invitedById])
  @@index([status])
  @@index([role])
  @@index([email])
  @@index([phone])
  @@index([createdAt])
}

model ProviderOrganization {
  id             String   @id @default(cuid())
  providerId     String
  organizationId String
  isPrimary      Boolean  @default(false)
  active         Boolean  @default(true)
  serviceZones   Json?
  createdAt      DateTime @default(now())

  provider     User         @relation(fields: [providerId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([providerId, organizationId])
  @@index([organizationId, active])
  @@index([providerId, active])
}

model Report {
  id                        String             @id @default(cuid())
  title                     String
  description               String
  category                  String
  location                  String
  latitude                  Float?
  longitude                 Float?
  status                    ReportStatus       @default(PENDING)
  organizationId            String
  citizenId                 String
  assignedProviderId        String?
  assignedAt                DateTime?
  assignmentDeadlineAt      DateTime?
  lastAssignmentOutcome     AssignmentOutcome?
  lastAssignmentReason      String?
  lastAssignmentAt          DateTime?
  lastAssignmentProviderId  String?
  completionNote            String?
  completionImageUrl        String?
  completionImagePath       String?
  evidenceImageUrl          String?
  evidenceImagePath         String?
  completedByProviderAt     DateTime?
  citizenRating             Int?
  citizenFeedback           String?
  completionRejectionReason String?
  isDemo                    Boolean            @default(false)
  demoBatchId               String?
  demoScenario              String?
  demoGeneratedAt           DateTime?
  createdBySuperAdminId     String?
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt

  organization     Organization     @relation(fields: [organizationId], references: [id])
  citizen          User             @relation("CitizenReports", fields: [citizenId], references: [id])
  assignedProvider User?            @relation("AssignedProviderReports", fields: [assignedProviderId], references: [id])
  notifications    Notification[]
  activities       ReportActivity[]

  @@index([organizationId])
  @@index([citizenId])
  @@index([assignedProviderId])
  @@index([status])
  @@index([isDemo])
  @@index([demoBatchId])
  @@index([demoScenario])
}

model ReportActivity {
  id             String        @id @default(cuid())
  reportId       String
  organizationId String
  actorUserId    String?
  actorRole      UserRole?
  actorName      String?
  action         String
  fromStatus     ReportStatus?
  toStatus       ReportStatus?
  providerId     String?
  reason         String?
  note           String?
  metadata       Json?
  createdAt      DateTime      @default(now())

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId, createdAt])
  @@index([organizationId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([action])
}

model Notification {
  id                    String    @id @default(cuid())
  userId                String
  reportId              String?
  type                  String
  title                 String
  message               String
  read                  Boolean   @default(false)
  isDemo                Boolean   @default(false)
  demoBatchId           String?
  demoScenario          String?
  demoGeneratedAt       DateTime?
  createdBySuperAdminId String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  report Report? @relation(fields: [reportId], references: [id])

  @@index([userId, read])
  @@index([reportId])
  @@index([createdAt])
  @@index([isDemo])
  @@index([demoBatchId])
  @@index([demoScenario])
}

model DemoAuditLog {
  id          String   @id @default(cuid())
  action      String
  actorUserId String
  demoBatchId String?
  scenario    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([action])
  @@index([actorUserId])
  @@index([demoBatchId])
  @@index([createdAt])
}

model PlatformSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model PlatformBackup {
  id           String    @id @default(cuid())
  fileName     String    @unique
  filePath     String
  sizeBytes    Int
  status       String    @default("READY")
  createdById  String
  restoredAt   DateTime?
  restoredById String?
  createdAt    DateTime  @default(now())

  @@index([createdAt])
  @@index([createdById])
  @@index([status])
}
