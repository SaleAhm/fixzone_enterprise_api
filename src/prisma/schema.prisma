generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}
enum UserRole {
  SUPER_ADMIN
  ORG_ADMIN
  DISPATCH_OFFICER
  PROVIDER
  CITIZEN
}

enum ReportStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  COMPLETED_BY_PROVIDER
  CLOSED
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  users     User[]
  reports   Report[]
}

model User {
  id             String   @id @default(cuid())
  email          String?  @unique
  phone          String?  @unique
  passwordHash   String?
  fullName       String
  role           UserRole
  organizationId String?

  organization   Organization? @relation(fields: [organizationId], references: [id])
}

model Report {
  id             String       @id @default(cuid())
  title          String
  description    String
  status         ReportStatus @default(PENDING)
  organizationId String
  citizenId      String

  organization   Organization @relation(fields: [organizationId], references: [id])
}